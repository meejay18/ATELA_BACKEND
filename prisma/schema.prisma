
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url = env("DATABASE_URL")
}

 enum  TenantStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
 }

enum OrderStatus {
PENDING
IN_PROGRESS
COMPLETED
CANCELLED
}

enum TaskType {
  PATTERN_MAKING
  CUTTING
  TAILORING
  QUALITY_CHECK
}

enum TaskStatus {
  PENDING
  IN_PROGRESS
  COMPLETED
  BLOCKED
}

enum InventoryCategory {
  FABRIC
  THREAD
  BUTTON
  ZIPPER
  LINING
  ACCESSORY
  OTHER
}

enum NotificationType {
  ORDER_CREATED
  ORDER_UPDATED
  TASK_ASSIGNED
  TASK_COMPLETED
  INVENTORY_LOW
  PAYMENT_RECORDED
}

enum UserRole {
  SUPER_ADMIN
  ADMIN
  FLOOR_MANAGER
  PATTERN_MAKER
  CUTTER
  TAILOR
  QUALITY_CONTROL
}

enum VerificationType {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  TWO_FACTOR
}

enum Currency {
  USD
  EUR
  GBP
  NGN
}

model Tenant {
  id String @id @default(uuid())
  name String 
  teamSize Int?
  slug String @unique
  currency  Currency @default(NGN)
  isOnboarded Boolean @default(false)
  isSuspended Boolean @default(false)
  status TenantStatus @default(ACTIVE)


  users User[]
  orders Order[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

}

model User {
  id String @id @default(uuid())
  tenantId String? 
  tenant Tenant? @relation(fields: [tenantId], references: [id])
  firstName String?
  lastName String?
  email String @unique
  password String
  role UserRole @default(ADMIN)
  isVerified Boolean @default(false)
  verifiedAt DateTime?
  isActive Boolean @default(true)

  orders Order[]
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  refreshToken RefreshToken[]
  verificationCodes verificationCode[]


  @@index([tenantId])
  @@index([email])
}

model RefreshToken  {
  id String @id @default(uuid())
  userId String 
  user User @relation(fields : [userId], references: [id])
  token String
  expiresAt DateTime 
  revoked Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}


model verificationCode {
  id String @id @default(uuid())
  userId String
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  code String
  type VerificationType 
  expiresAt DateTime
  usedAt DateTime?
  revoked Boolean @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([code])
}

enum OrderType {
  CUSTOM_ORDER
  READY_TO_WEAR
}

enum ProductionStage {
  PATTERN_MAKING
  CUTTING
  TAILORING
  FINISHING
  QUALITY_CONTROL
  PACKAGING
}

model Order {
  id String @id @default(uuid())
  tenantId String
  createdById String
  orderNumber String @unique
  orderType OrderType
  description String?
  status OrderStatus @default(PENDING)
  garmentType String
  quantity Int
  deadline DateTime?
  stageToStart  ProductionStage
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  tenant Tenant  @relation(fields: [tenantId], references: [id])
  createdBy User @relation(fields: [createdById], references:[id])

  customOrder CustomOrder?
  readyToWear ReadyToWear? 

}

model CustomOrder {
  id String @id @default(uuid())
  orderId String @unique
  clientName String 
  clientPhone String?

  order Order @relation(fields:[orderId], references:[id], onDelete: Cascade)
}

model ReadyToWear {
  id String @id @default(uuid())
  orderId String @unique

  order Order @relation(fields:[orderId], references:[id], onDelete: Cascade)
}